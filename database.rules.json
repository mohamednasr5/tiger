{
  "rules": {
    "products": {
      ".read": true,
      ".indexOn": ["category", "createdAt", "status", "bestSeller", "newArrival", "featured"],
      "$productId": {
        ".write": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())"
      }
    },
    "categories": {
      ".read": true,
      ".write": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())"
    },
    "orders": {
      ".read": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())",
      ".indexOn": ["userId", "status", "createdAt"],
      "$orderId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || auth.token.admin === true || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())"
      }
    },
    "users": {
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || auth.token.admin === true || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $userId || auth.token.admin === true || root.child('admins').child(auth.uid).exists())"
      }
    },
    "cart": {
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || auth.token.admin === true)",
        ".write": "auth != null && (auth.uid === $userId || auth.token.admin === true)"
      }
    },
    "wishlist": {
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || auth.token.admin === true)",
        ".write": "auth != null && (auth.uid === $userId || auth.token.admin === true)"
      }
    },
    "reviews": {
      ".read": true,
      "$productId": {
        ".write": "auth != null",
        ".indexOn": ["createdAt"]
      }
    },
    "paymentConfirmations": {
      ".read": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())",
      "$orderId": {
        ".write": "auth != null"
      }
    },
    "newsletter": {
      ".read": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())",
      ".write": true
    },
    "banners": {
      ".read": true,
      ".write": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())"
    },
    "coupons": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())"
    },
    "settings": {
      ".read": true,
      ".write": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())"
    },
    "admins": {
      ".read": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())",
      ".write": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())"
    },
    "fcmTokens": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId"
      }
    },
    "analytics": {
      ".read": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())",
      ".write": "auth != null && (auth.token.admin === true || root.child('admins').child(auth.uid).exists())"
    }
  }
}